    {
      "name": "OAuth Setup",
      "item": [
        {
          "name": "Generate PKCE Values",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function base64UrlEncodeWordArray(wordArray) {",
                  "    return CryptoJS.enc.Base64.stringify(wordArray)",
                  "        .replace(/\\+/g, '-')",
                  "        .replace(/\\//g, '_')",
                  "        .replace(/=+$/, '');",
                  "}",
                  "",
                  "function randomString(length) {",
                  "    const charset = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~';",
                  "    let result = '';",
                  "    for (let i = 0; i < length; i++) {",
                  "        result += charset.charAt(Math.floor(Math.random() * charset.length));",
                  "    }",
                  "    return result;",
                  "}",
                  "",
                  "const codeVerifier = randomString(96);",
                  "const hashed = CryptoJS.SHA256(codeVerifier);",
                  "const codeChallenge = base64UrlEncodeWordArray(hashed);",
                  "",
                  "pm.environment.set('code_verifier', codeVerifier);",
                  "pm.environment.set('code_challenge', codeChallenge);",
                  "",
                  "console.log('code_verifier:', codeVerifier);",
                  "console.log('code_challenge:', codeChallenge);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('PKCE variables are set', function () {",
                  "    pm.expect(pm.environment.get('code_verifier')).to.be.a('string').and.not.empty;",
                  "    pm.expect(pm.environment.get('code_challenge')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}",
              "host": [
                "{{base_url}}"
              ]
            },
            "description": "Helper request to generate PKCE values in the Pre-request Script."
          },
          "response": []
        },
        {
          "name": "Open Authorize URL Helper",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function base64UrlEncodeWordArray(wordArray) {",
                  "    return CryptoJS.enc.Base64.stringify(wordArray)",
                  "        .replace(/\\+/g, '-')",
                  "        .replace(/\\//g, '_')",
                  "        .replace(/=+$/, '');",
                  "}",
                  "",
                  "function randomString(length) {",
                  "    const charset = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~';",
                  "    let result = '';",
                  "    for (let i = 0; i < length; i++) {",
                  "        result += charset.charAt(Math.floor(Math.random() * charset.length));",
                  "    }",
                  "    return result;",
                  "}",
                  "",
                  "if (!pm.environment.get('code_verifier') || !pm.environment.get('code_challenge')) {",
                  "    const codeVerifier = randomString(96);",
                  "    const hashed = CryptoJS.SHA256(codeVerifier);",
                  "    const codeChallenge = base64UrlEncodeWordArray(hashed);",
                  "    pm.environment.set('code_verifier', codeVerifier);",
                  "    pm.environment.set('code_challenge', codeChallenge);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Response status is redirect or success', function () {",
                  "    pm.expect([200, 302, 303]).to.include(pm.response.code);",
                  "});",
                  "",
                  "const locationHeader = pm.response.headers.get('Location');",
                  "",
                  "if (locationHeader) {",
                  "    pm.environment.set('last_location', locationHeader);",
                  "    const match = locationHeader.match(/[?&]code=([^&]+)/);",
                  "    if (match && match[1]) {",
                  "        const code = decodeURIComponent(match[1]);",
                  "        pm.environment.set('authorization_code', code);",
                  "        console.log('authorization_code captured:', code);",
                  "    }",
                  "}",
                  "",
                  "pm.test('Location header check completed', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/html"
              }
            ],
            "url": {
              "raw": "{{base_url}}/oauth/authorize?response_type=code&client_id={{client_id}}&redirect_uri={{redirect_uri}}&scope={{scope}}&state=local-dev-state&code_challenge={{code_challenge}}&code_challenge_method=S256",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "oauth",
                "authorize"
              ],
              "query": [
                {
                  "key": "response_type",
                  "value": "code"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{redirect_uri}}"
                },
                {
                  "key": "scope",
                  "value": "{{scope}}"
                },
                {
                  "key": "state",
                  "value": "local-dev-state"
                },
                {
                  "key": "code_challenge",
                  "value": "{{code_challenge}}"
                },
                {
                  "key": "code_challenge_method",
                  "value": "S256"
                }
              ]
            },
            "description": "If browser session login is required, open this same URL manually in a browser and copy the code query parameter into the authorization_code environment variable."
          },
          "response": []
        }
