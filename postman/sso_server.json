        {
          "name": "Token Exchange",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response contains backend wrapper', function () {",
                  "    pm.expect(json).to.have.property('message');",
                  "    pm.expect(json).to.have.property('data');",
                  "    pm.expect(json).to.have.property('meta');",
                  "    pm.expect(json).to.have.property('errors');",
                  "});",
                  "",
                  "pm.test('Response contains tokens', function () {",
                  "    pm.expect(json.data).to.have.property('access_token');",
                  "    pm.expect(json.data).to.have.property('refresh_token');",
                  "    pm.expect(json.data).to.have.property('token_type');",
                  "});",
                  "",
                  "pm.environment.set('access_token', json.data.access_token);",
                  "pm.environment.set('refresh_token', json.data.refresh_token);",
                  "",
                  "if (json.data.scope) {",
                  "    pm.environment.set('scope', json.data.scope);",
                  "}"
                ]
              }
            }
